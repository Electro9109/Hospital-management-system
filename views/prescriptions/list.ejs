<%- include('../partials/header') %>
    <div class="app-layout">
        <%- include('../partials/sidebar') %>
            <main class="main-content">
                <% if (success) { %>
                    <div class="alert alert-success">✅ <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div class="alert alert-error">⚠️ <%= error %>
                            </div>
                            <% } %>

                                <div class="page-header">
                                    <div>
                                        <h2>Prescriptions</h2>
                                        <p>View all prescriptions</p>
                                    </div>
                                    <div class="search-bar">
                                        <span class="search-icon">🔍</span>
                                        <input type="text" placeholder="Search prescriptions..."
                                            data-search=".presc-row">
                                    </div>
                                </div>

                                <div class="table-container animate-in">
                                    <table>
                                        <thead>
    <tr>
        <th>ID</th>
        <th>Patient</th>
        <th>Doctor</th>
        <th>Diagnosis</th>
        <th>Follow-up</th>
        <th>Verified</th>
        <th>Actions</th>
    </tr>
</thead>
<tbody>
    <% prescriptions.forEach(function(pr) { %>
        <tr>
            <td class="primary-text">#<%= pr.PRESCRIPTION_ID %></td>
            <td><%= pr.PATIENT_NAME %></td>
            <td><%= pr.DOCTOR_NAME %></td>
            <td><%= pr.DIAGNOSIS || '—' %></td>
            <td><%= pr.FOLLOW_UP_DATE ? new Date(pr.FOLLOW_UP_DATE).toLocaleDateString('en-IN') : '—' %></td>
            <td>
                <% if (pr.VERIFIED_BY_STAFF_ID) { %>
                    <%- statusBadge('verified') %>
                <% } else { %>
                    <%- statusBadge('pending') %>
                <% } %>
            </td>
            <td>
                <a href="/prescriptions/<%= pr.PRESCRIPTION_ID %>" class="btn btn-sm btn-secondary">View</a>
                <% if (!pr.VERIFIED_BY_STAFF_ID && ['receptionist','nurse','admin'].includes(user.role.toLowerCase())) { %>
                    <form action="/prescriptions/<%= pr.PRESCRIPTION_ID %>/verify" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-primary">Verify</button>
                    </form>
                <% } %>
            </td>
        </tr>
    <% }); %>
</tbody>
                                    </table>
                                </div>
            </main>
    </div>
    <%- include('../partials/footer') %>