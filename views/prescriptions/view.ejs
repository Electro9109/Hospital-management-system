<%- include('../partials/header') %>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <main class="main-content">

        <div class="card animate-in" id="rx-card">
            <div class="card-header">
                <h3>💊 Prescription #<%= prescription.PRESCRIPTION_ID %></h3>
                <div style="display: flex; gap: 0.5rem;">
                    <button onclick="window.print()" class="btn btn-sm btn-secondary">🖨️ Print</button>
                    <a href="/prescriptions" class="btn btn-sm btn-secondary">← Back</a>
                </div>
            </div>

            <div style="padding: 2rem;">
                <!-- Header -->
                <div style="text-align: center; margin-bottom: 2rem; border-bottom: 2px solid var(--border); padding-bottom: 1rem;">
                    <h2 style="margin: 0;">🏥 City Hospital</h2>
                    <p style="margin: 0; color: var(--text-muted);">Medical Prescription</p>
                </div>

                <!-- Doctor & Patient Info -->
                <div class="content-grid" style="margin-bottom: 1.5rem;">
                    <div>
                        <p><strong>Patient:</strong> <%= prescription.PATIENT_NAME %></p>
                        <p><strong>Phone:</strong> <%= prescription.PHONE || '—' %></p>
                        <p><strong>Gender:</strong> <%= prescription.GENDER || '—' %></p>
                        <p><strong>Blood Group:</strong> <%= prescription.BLOOD_GROUP || '—' %></p>
                    </div>
                    <div>
                        <p><strong>Doctor:</strong> Dr. <%= prescription.DOCTOR_NAME %></p>
                        <p><strong>Specialization:</strong> <%= prescription.SPECIALIZATION || '—' %></p>
                        <p><strong>Date:</strong> <%= new Date(prescription.CREATED_AT).toLocaleDateString('en-IN') %></p>
                        <p>
                            <strong>Status:</strong>
                            <% if (prescription.VERIFIED_BY_STAFF_ID) { %>
                                <%- statusBadge('verified') %>
                            <% } else { %>
                                <%- statusBadge('pending') %>
                            <% } %>
                        </p>
                    </div>
                </div>

                <!-- Rx Symbol + Medicine -->
                <div style="background: var(--bg-secondary); border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem;">
    <h4 style="margin: 0 0 1rem 0; font-size: 1.2rem;">℞</h4>
    <p><strong>Diagnosis:</strong> <%= prescription.DIAGNOSIS || '—' %></p>
    <p><strong>Notes / Prescription:</strong> <%= prescription.NOTES || '—' %></p>
    <p><strong>Follow-up Date:</strong> <%= prescription.FOLLOW_UP_DATE ? new Date(prescription.FOLLOW_UP_DATE).toLocaleDateString('en-IN') : 'None' %></p>
    <p><strong>Appointment Date:</strong> <%= new Date(prescription.APPOINTMENT_DATE).toLocaleDateString('en-IN') %></p>
</div>

                <!-- Verify button -->
                <% if (!prescription.VERIFIED_BY_STAFF_ID && ['receptionist','nurse','admin'].includes(user.role.toLowerCase())) { %>
                    <form action="/prescriptions/<%= prescription.PRESCRIPTION_ID %>/verify" method="POST">
                        <button type="submit" class="btn btn-primary">✅ Verify Prescription</button>
                    </form>
                <% } %>
            </div>
        </div>

        <style>
            @media print {
                .sidebar, .card-header .btn, form, button { display: none !important; }
                .main-content { margin: 0; padding: 0; }
                #rx-card { box-shadow: none; border: none; }
            }
        </style>

    </main>
</div>
<%- include('../partials/footer') %>
```

