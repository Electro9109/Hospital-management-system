<%- include('../partials/header') %>
    <div class="app-layout">
        <%- include('../partials/sidebar') %>
            <main class="main-content">
                <% if (success) { %>
                    <div class="alert alert-success">✅ <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div class="alert alert-error">⚠️ <%= error %>
                            </div>
                            <% } %>

                                <div class="page-header">
                                    <div>
                                        <h2>Doctor Availability</h2>
                                        <p>Manage doctor schedules</p>
                                    </div>
                                    <a href="/doctors" class="btn btn-secondary">← Doctors</a>
                                </div>

                                <!-- Add Slot Form -->
                                <div class="card animate-in mb-3">
                                    <div class="card-header">
                                        <h3>➕ Add Availability Slot</h3>
                                    </div>
                                    <form method="POST" action="/doctors/availability">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="doctor_id">Doctor</label>
                                                <select class="form-control" id="doctor_id" name="doctor_id" required>
                                                    <option value="">Select Doctor</option>
                                                    <% doctors.forEach(function(d) { %>
                                                        <option value="<%= d.DOCTOR_ID %>">Dr. <%= d.NAME %>
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label for="day">Day</label>
                                                <select class="form-control" id="day" name="day" required>
                                                    <option value="Monday">Monday</option>
                                                    <option value="Tuesday">Tuesday</option>
                                                    <option value="Wednesday">Wednesday</option>
                                                    <option value="Thursday">Thursday</option>
                                                    <option value="Friday">Friday</option>
                                                    <option value="Saturday">Saturday</option>
                                                    <option value="Sunday">Sunday</option>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label for="start_time">Start</label>
                                                <input type="text" class="form-control" id="start_time"
                                                    name="start_time" placeholder="09:00" required>
                                            </div>
                                            <div class="form-group">
                                                <label for="end_time">End</label>
                                                <input type="text" class="form-control" id="end_time" name="end_time"
                                                    placeholder="17:00" required>
                                            </div>
                                            <div class="form-group">
                                                <label for="slot_mins">Slot (min)</label>
                                                <input type="number" class="form-control" id="slot_mins"
                                                    name="slot_mins" value="30" required>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-primary" style="margin-top: 8px;">Add
                                            Slot</button>
                                    </form>
                                </div>

                                <!-- Current Slots -->
                                <div class="table-container animate-in">
                                    <table>
                                        <thead>
                                            <tr>
                                                <th>Doctor</th>
                                                <th>Day</th>
                                                <th>Start</th>
                                                <th>End</th>
                                                <th>Slot Duration</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (slots.length===0) { %>
                                                <tr>
                                                    <td colspan="5"
                                                        style="text-align:center;padding:40px;color:var(--text-muted);">
                                                        No availability slots</td>
                                                </tr>
                                                <% } %>
                                                    <% slots.forEach(function(s) { %>
                                                        <tr>
                                                            <td class="primary-text">Dr. <%= s.DOCTOR_NAME %>
                                                            </td>
                                                            <td>
                                                                <%= s.DAY %>
                                                            </td>
                                                            <td>
                                                                <%= formatTime(s.START_TIME) %>
                                                            </td>
                                                            <td>
                                                                <%= formatTime(s.END_TIME) %>
                                                            </td>
                                                            <td>
                                                                <%= s.SLOT_MINS %> min
                                                            </td>
                                                        </tr>
                                                        <% }); %>
                                        </tbody>
                                    </table>
                                </div>
            </main>
    </div>
    <%- include('../partials/footer') %>