<%- include('../partials/header') %>
    <div class="app-layout">
        <%- include('../partials/sidebar') %>
            <main class="main-content">
                <% if (success) { %>
                    <div class="alert alert-success">✅ <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div class="alert alert-error">⚠️ <%= error %>
                            </div>
                            <% } %>

                                <div class="page-header">
                                    <div>
                                        <h2>
                                            <%= pageTitle %>
                                        </h2>
                                        <% if (staffName) { %>
                                            <p>Shifts for: <strong>
                                                    <%= staffName %>
                                                </strong></p>
                                            <% } %>
                                    </div>
                                    <% if (user.role.toLowerCase()==='admin' ) { %>
                                        <a href="/staff" class="btn btn-secondary">← Staff List</a>
                                        <% } %>
                                </div>

                                <!-- Add Shift Form (Admin only) -->
                                <% if (user.role.toLowerCase()==='admin' ) { %>
                                    <div class="card animate-in mb-3">
                                        <div class="card-header">
                                            <h3>➕ Assign New Shift</h3>
                                        </div>
                                        <form method="POST" action="/staff/shifts">
                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="staff_id">Staff Member</label>
                                                    <select class="form-control" id="staff_id" name="staff_id" required>
                                                        <option value="">Select Staff</option>
                                                        <% staffList.forEach(function(s) { %>
                                                            <option value="<%= s.STAFF_ID %>">
                                                                <%= s.NAME %>
                                                            </option>
                                                            <% }); %>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <label for="shift_date">Date</label>
                                                    <input type="date" class="form-control" id="shift_date"
                                                        name="shift_date" required>
                                                </div>
                                                <div class="form-group">
                                                    <label for="start_time">Start Time</label>
                                                    <input type="text" class="form-control" id="start_time"
                                                        name="start_time" placeholder="e.g. 08:00" required>
                                                </div>
                                                <div class="form-group">
                                                    <label for="end_time">End Time</label>
                                                    <input type="text" class="form-control" id="end_time"
                                                        name="end_time" placeholder="e.g. 16:00" required>
                                                </div>
                                                <div class="form-group">
                                                    <label for="shift_type">Type</label>
                                                    <select class="form-control" id="shift_type" name="shift_type"
                                                        required>
                                                        <option value="Morning">Morning</option>
                                                        <option value="Afternoon">Afternoon</option>
                                                        <option value="Night">Night</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <button type="submit" class="btn btn-primary"
                                                style="margin-top: 8px;">Assign Shift</button>
                                        </form>
                                    </div>
                                    <% } %>

                                        <!-- Shifts Table -->
                                        <div class="table-container animate-in">
                                            <table>
                                                <thead>
                                                    <tr>
                                                        <th>Date</th>
                                                        <th>Staff</th>
                                                        <th>Time</th>
                                                        <th>Type</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (shifts.length===0) { %>
                                                        <tr>
                                                            <td colspan="4"
                                                                style="text-align:center;padding:40px;color:var(--text-muted);">
                                                                No shifts found</td>
                                                        </tr>
                                                        <% } %>
                                                            <% shifts.forEach(function(s) { %>
                                                                <tr>
                                                                    <td class="primary-text">
                                                                        <%= formatDate(s.SHIFT_DATE) %>
                                                                    </td>
                                                                    <td>
                                                                        <%= s.STAFF_NAME %>
                                                                    </td>
                                                                    <td>
                                                                        <%= formatTime(s.START_TIME) %> — <%=
                                                                                formatTime(s.END_TIME) %>
                                                                    </td>
                                                                    <td><%- statusBadge(s.SHIFT_TYPE) %></td>
                                                                </tr>
                                                                <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
            </main>
    </div>
    <%- include('../partials/footer') %>