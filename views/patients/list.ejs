<%- include('../partials/header') %>
    <div class="app-layout">
        <%- include('../partials/sidebar') %>
            <main class="main-content">

                <% if (success) { %>
                    <div class="alert alert-success">✅ <%= success %>
                    </div>
                    <% } %>
                        <% if (error) { %>
                            <div class="alert alert-error">⚠️ <%= error %>
                            </div>
                            <% } %>

                                <div class="page-header">
                                    <div>
                                        <h2>Patients</h2>
                                        <p>Manage patient records</p>
                                    </div>
                                    <div class="page-actions">
                                        <div class="search-bar">
                                            <span class="search-icon">🔍</span>
                                            <input type="text" placeholder="Search patients..."
                                                data-search=".patient-row">
                                        </div>
                                        <% if (['receptionist','admin'].includes(user.role.toLowerCase())) { %>
                                            <a href="/patients/register" class="btn btn-primary">+ Register Patient</a>
                                            <% } %>
                                    </div>
                                </div>

                                <div class="table-container animate-in">
                                    <table>
                                        <thead>
                                            <tr>
                                                <th>ID</th>
                                                <th>Name</th>
                                                <th>Phone</th>
                                                <th>Gender</th>
                                                <th>Blood Group</th>
                                                <th>DOB</th>
                                                <th>Email</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (patients.length===0) { %>
                                                <tr>
                                                    <td colspan="8"
                                                        style="text-align:center; padding:40px; color: var(--text-muted);">
                                                        No patients found</td>
                                                </tr>
                                                <% } %>
                                                    <% patients.forEach(function(p) { %>
                                                        <tr class="patient-row"
                                                            data-href="/patients/<%= p.PATIENT_ID %>">
                                                            <td class="primary-text">#<%= p.PATIENT_ID %>
                                                            </td>
                                                            <td class="primary-text">
                                                                <%= p.NAME %>
                                                            </td>
                                                            <td>
                                                                <%= p.PHONE || '—' %>
                                                            </td>
                                                            <td>
                                                                <%= p.GENDER || '—' %>
                                                            </td>
                                                            <td><span class="badge badge-info">
                                                                    <%= p.BLOOD_GROUP || '—' %>
                                                                </span></td>
                                                            <td>
                                                                <%= formatDate(p.DOB) %>
                                                            </td>
                                                            <td>
                                                                <%= p.EMAIL || '—' %>
                                                            </td>
                                                            <td>
                                                                <a href="/patients/<%= p.PATIENT_ID %>"
                                                                    class="btn btn-sm btn-secondary">View</a>
                                                            </td>
                                                        </tr>
                                                        <% }); %>
                                        </tbody>
                                    </table>
                                </div>

            </main>
    </div>
    <%- include('../partials/footer') %>